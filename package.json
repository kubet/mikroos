{
  "name": "mikroos",
  "private": true,
  "version": "0.1.0",
  "description": "Browser-native AI coding agent. Runs a local LLM, a Linux-like sandbox, and a real terminal entirely in your browser.",
  "license": "MIT",
  "homepage": "https://mikroos.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kubet/mikroos.git"
  },
  "bugs": {
    "url": "https://github.com/kubet/mikroos/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "webgpu",
    "webllm",
    "transformers",
    "browser-native",
    "local-first",
    "coding-agent",
    "sandbox",
    "solid-js",
    "pixel-art"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "host": "vite --host",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.1.0",
    "@lifo-sh/core": "^0.5.5",
    "@lifo-sh/ui": "^0.5.0",
    "@mlc-ai/web-llm": "^0.2.82",
    "@mozilla/readability": "^0.6.0",
    "@tailwindcss/vite": "^4.2.2",
    "marked": "^18.0.0",
    "solid-js": "^1.9.12",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.4"
  }
}